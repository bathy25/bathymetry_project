  }
});

thumbPanel.add(
  ui.Label('Bathymetric Map', {
    fontWeight: 'bold',
    margin: '0 0 6px 0',
    textAlign: 'left'
  })
);

thumbPanel.add(mapAndLegend);
chartPanel.add(thumbPanel);

 // ---------- Validation ----------
validationResults = linearSDB.sampleRegions({
  collection: validPts,
  properties: [depthName],
  scale: scale
}).filter(ee.Filter.notNull(['modeled_depth', depthName]));


// ---------- RMSE ----------
var sqResiduals = validationResults.map(function(f){
  var obs = ee.Number(f.get(depthName));
  var pred = ee.Number(f.get('modeled_depth'));
  return ee.Feature(null, {sq: obs.subtract(pred).pow(2)});
});

var mse = ee.Number(sqResiduals.reduceColumns(ee.Reducer.mean(), ['sq']).get('mean'));

mse.sqrt().evaluate(function(rmseVal) {
  if (rmseVal === null || isNaN(rmseVal)) {
    rmseLabel.setValue('RMSE: N/A');
  } else {
    rmseLabel.setValue('RMSE: ' + safeToFixed(rmseVal, 3) + ' m');
  }
});


// ---------- R² Calculation ----------
var stats = validationResults.reduceColumns({
  reducer: ee.Reducer.pearsonsCorrelation(),
  selectors: ['modeled_depth', depthName]
});

var r = ee.Number(stats.get('correlation'));
var r2 = r.pow(2);


// ---------- Scatterplot ----------
r2.evaluate(function(r2val) {

  var r2text = (r2val === null || isNaN(r2val)) ? 'N/A' : safeToFixed(r2val, 3);

  validationResults.aggregate_array('modeled_depth').evaluate(function(arr) {

    if (arr && arr.length > 0) {

      var chart = ui.Chart.feature.byFeature(
          validationResults,
          'modeled_depth',
          depthName
        )
        .setChartType('ScatterChart')
        .setOptions({
          title: 'Validation: Modeled vs Measured Depth',
          hAxis: { title: 'Modeled Depth (m)' },
          vAxis: { title: 'Measured Depth (m)' },

          // --- POINT SERIES NAME ---
          series: {
            0: {
              color: 'black',
              pointSize: 5,
              visibleInLegend: true,
              labelInLegend: 'Depth'
            }
          },

          // --- REGRESSION LINE NAME ---
          trendlines: {
            0: {
              showR2: true,
              visibleInLegend: true,
              color: 'black',
              lineWidth: 2,
              labelInLegend: 'Regression'
            }
          }
        });

      chartPanel.add(chart);

    } else {
      chartPanel.add(ui.Label('No validation points available for scatterplot.'));
    }

  });

});

  // -------- CSV URL outputs (Modeled Depth first) ----------
  var validationAll = validPts.map(function(f){
    var coords = f.geometry().coordinates();
    var modeled = linearSDB.reduceRegion({
      reducer: ee.Reducer.first(),
      geometry: f.geometry(),
      scale: scale
    }).get('modeled_depth');

    return f.set({
      X: coords.get(0),
      Y: coords.get(1),
      modeled_depth: modeled
    });
  }).filter(ee.Filter.notNull(['X','Y','modeled_depth']));

  // Create download panel
  downloadPanel = ui.Panel({ layout: ui.Panel.Layout.flow('vertical'), style: {margin:'10px 0'} });

  validationAll.size().evaluate(function(cnt) {
    if (cnt > 0) {
      var url = validationAll.getDownloadURL({ format: 'CSV', selectors: ['X','Y','modeled_depth'] });
      var downloadUrlLabel = ui.Label('⬇ Download Modeled Depth CSV', {
        color:'blue', fontSize:'14px', fontWeight:'bold', textDecoration:'underline', margin: '4px 0'
      });
      downloadUrlLabel.setUrl(url);
      downloadPanel.add(downloadUrlLabel);
    } else {
      downloadPanel.add(ui.Label('No modeled-depth values available for CSV export.'));
    }

    var metadata = ee.Feature(null, {
      bay: bayName,
      image: selectedLabel,
      year: yearDropdown.getValue(),
      model: 'Lyzenga log-linear regression',
      RMSE: rmseLabel.getValue()
    });
    var metadataUrl = ee.FeatureCollection([metadata]).getDownloadURL({
      format:'CSV',
      selectors:['bay','image','year','model','RMSE']
    });
    var metadataUrlLabel = ui.Label('⬇ Download Metadata CSV', {
      color:'blue', fontSize:'14px', fontWeight:'bold', textDecoration:'underline', margin: '4px 0 0 0'
    });
    metadataUrlLabel.setUrl(metadataUrl);
    downloadPanel.add(metadataUrlLabel);

    var clearButton = ui.Button({
      label: 'Clear Downloads',
      style: {stretch:'horizontal', margin:'6px 0'},
      onClick: function() { mainPanel.remove(downloadPanel); downloadPanel = undefined; }
    });
    downloadPanel.add(clearButton);

    mainPanel.add(downloadPanel);
  });

  // --------- Map click inspection ----------
  Map.onClick(function(coords) {
    if (!modelOutputImage) {
      infoPanel.clear();
      infoPanel.add(ui.Label('Run the model first.'));
      return;
    }
    var pt = ee.Geometry.Point([coords.lon, coords.lat]);
    modelOutputImage.reduceRegion({
      reducer: ee.Reducer.first(),
      geometry: pt,
      scale: scale
    }).get('modeled_depth').evaluate(function(val) {
      infoPanel.clear();
      infoPanel.add(ui.Label('Modeled Depth: ' + (val === null ? 'N/A' : safeToFixed(val, 2) + ' m')));
    });
  });
  print('\u2705 runModel finished for: ' + bayName);
}
 // <--- End of runModel()
 
