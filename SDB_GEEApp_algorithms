// ----------------------- Safe toFixed --------------------------------------------------------------------------------
function safeToFixed(val, digits) {
  var num = Number(val);
  var dec = Number(digits);
  if (isNaN(num)) return 'N/A';
  if (isNaN(dec) || dec < 0) dec = 2;
  if (dec > 100) dec = 100;
  return num.toFixed(dec);
}

//------------------------- Declare Global Variables ------------------------------------------------------------------------
var modelOutputImage;    // keep this ONE declaration globally
var validationResults;   // if used globally
var downloadPanel;       // global for download panel

// ----------------------- Run Lyzenga Model ----------------------------------------------------------------------------
function runModel() {
  // clear UI
  imageInfoPanel.clear();
  chartPanel.clear();
  rmseLabel.setValue('RMSE: N/A');

  // Remove previous download panel if exists
  if (downloadPanel !== undefined) {
    mainPanel.remove(downloadPanel);
    downloadPanel = undefined;
  }
  var bayName = baySelect.getValue();
  if (!bayName) return;
  var bay = bayAssets[bayName];
  var selectedLabel = imageSelect.getValue();
  if (!selectedLabel) return;
  var imageId = imageSelect.labelToId[selectedLabel];
  if (!imageId) return;

  // load image clipped to bay
  var image = ee.Image(imageId).clip(bay.poi);

  // Detect sensor and set bands/scale
  var isLandsat = (String(imageId).indexOf('Landsat-8') !== -1);
  var scale = isLandsat ? 30 : 10;
  var rgbBands = isLandsat ? ['SR_B4','SR_B3','SR_B2'] : ['B4','B3','B2'];
  var workBands = isLandsat ? ['SR_B2','SR_B3','SR_B4'] : ['B2','B3','B4'];

  // Prepare layer names
  var date = ee.Date(image.get('system:time_start')).format('YYYY-MM-dd').getInfo();
  var platform = null;
  try {
    platform = image.get('SPACECRAFT_NAME').getInfo();
  } catch (e1) {
    try {
      platform = image.get('SPACECRAFT_ID').getInfo();
    } catch (e2) {
      platform = null;
    }
  }

  var layerInfo = [];
  if (platform) layerInfo.push(platform);
  if (date) layerInfo.push(date);
  var rgbLayerName = 'RGB | ' + layerInfo.join(' | ');
  var bathyLayerName = 'Bathymetry | Lyzenga Model | ' + layerInfo.join(' | ');

  // Add RGB to map
  Map.centerObject(bay.poi, 12);
  Map.addLayer(image, {bands: rgbBands, min:0, max: (isLandsat ? 2000 : 3000)}, rgbLayerName);

  // --- Lyzenga regression (log-linear with constant)
  var logBands = image.select(workBands).max(0.0001).log();
  var masked = logBands.updateMask(bay.land);

  // Prepare training and validation points
  var pts = bay.bathy
    .filter(ee.Filter.gte(depthName, bay.depthRange[0]))
    .filter(ee.Filter.lte(depthName, bay.depthRange[1]))
    .randomColumn('rnd');
  var trainPts = pts.filter(ee.Filter.lt('rnd', split));
  var validPts = pts.filter(ee.Filter.gte('rnd', split));
  var training = masked.sampleRegions({
    collection: trainPts,
    properties: [depthName],
    scale: scale
  }).map(function(f){ return f.set('constant', 1); });
  var selectors = ['constant'].concat(workBands).concat([depthName]);
  var lr = training.reduceColumns({
    reducer: ee.Reducer.linearRegression({ numX: 1 + workBands.length, numY: 1 }),
    selectors: selectors
  });
  var coeffs = ee.Array(lr.get('coefficients')).toList();

  // Build predicted depth image
  var linearSDB = masked.select(workBands[0]).multiply(ee.Number(coeffs.get(1)))
    .add(masked.select(workBands[1]).multiply(ee.Number(coeffs.get(2))))
    .add(masked.select(workBands[2]).multiply(ee.Number(coeffs.get(3))))
    .add(ee.Number(coeffs.get(0)))
    .rename('modeled_depth');

  modelOutputImage = linearSDB; // assign globally

  // Add bathymetry layer to map
  Map.addLayer(linearSDB, {
    min: bay.depthRange[0],
    max: bay.depthRange[1],
    palette: ['#0000FF','#00BFFF','#00FFBF','#7FFF00','#FFFF00']
  }, bathyLayerName);

 // ---------- Thumbnail & Vertical Legend ----------
var region = getRegionForBay(bayName);

var bathyVis = {
  min: bay.depthRange[0],
  max: bay.depthRange[1],
  palette: ['#0000FF', '#00BFFF', '#00FFBF', '#7FFF00', '#FFFF00']
};

var bathyThumb = ui.Thumbnail({
  image: linearSDB.visualize(bathyVis),
  params: { region: region, dimensions: 900, format: 'png' },
  style: {
