// ----------------------- Helper Functions ------------------------
function getBayGeometry(bayName){
  var geometries = {
    'Dublin': ee.Geometry.Point([-6.2603, 53.3498]),
    'Dungarvan': ee.Geometry.Point([-7.555485, 52.069617]),
    'Portrane': ee.Geometry.Point([-6.102671,53.452902]),
    'Rosses': ee.Geometry.Point([-8.3833, 54.9500]),
    'Tramore': ee.Geometry.Point([-7.1493, 52.1614])
  };
  return geometries[bayName];
}

function getRegionForBay(bayName){
  var bay = bayAssets[bayName];
  var baseGeom = ee.Algorithms.If(bay && bay.poi, ee.FeatureCollection(bay.poi).geometry(), getBayGeometry(bayName));
  return ee.Geometry(baseGeom).buffer(5000).bounds().transform('EPSG:4326',1);
}

